<% title t('.page_title') %>
<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    <h1 class="govuk-heading-xl"><%= t(".page_title") %></h1>
    <% month_ranges = 0.upto(11).map do |months_ago|
      month = months_ago.months.ago.to_date
      { from: month.beginning_of_month, to: month.end_of_month }
    end %>

    <% request_types_by_heading = {
      "CRM7" => [
        "non_standard_magistrate",
        "non_standard_mag_appeal",
        "non_standard_mag_amendment",
        "non_standard_mag_supplemental",
        "breach_of_injunction",
      ],
      "CRM8" => [
        "assigned_counsel",
        "assigned_counsel_appeal",
        "assigned_counsel_amendment",
        "assigned_counsel_supplemental",
      ],
    } %>

    <% request_types_by_heading.each do |heading, request_types| %>
      <h2><%= heading %></h2>
      <ul class="govuk-list">
        <% month_ranges.each do |month_range| %>
          <li>
            <%= link_to "#{month_range[:from]} to #{month_range[:to]}",
                        payments_download_index_path(
                          format: :csv,
                          request_type: request_types,
                          created_at_from: month_range[:from],
                          created_at_to: month_range[:to]
                        ) %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>
</div>

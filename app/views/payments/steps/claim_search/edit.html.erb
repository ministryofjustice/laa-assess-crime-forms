<% title t('.page_title') %>
<% step_header(path: previous_decision_step_path) %>
<%= govuk_error_summary(@form_object) %>
<% search_url_params = { anchor: 'search-results' } %>
<% search_url_params[:return_to_cya] = 1 if params[:return_to_cya].present? %>
<% search_table_params = { 'controller' => controller_path, 'action' => 'edit', 'payments_claim_search_form' => @search_form.attributes } %>
<% search_table_params['return_to_cya'] = params[:return_to_cya] if params[:return_to_cya].present? %>

<h1 class="govuk-heading-xl"><%= page_heading %></h1>
<p><%= t('.body_line_1') %></p>
<p><%= t('.body_line_2') %></p>
<p><%= t('.body_line_3') %></p>

<div class="moj-search moj-search--inline app-claim-search govuk-!-margin-bottom-5">
  <%= form_with(url: new_payments_steps_claim_search_path(search_url_params), method: :get, model: @search_form) do |f| %>
    <%= hidden_field_tag :return_to_cya, 1 if params[:return_to_cya].present? %>
    <div class="govuk-form-group" role="search">
      <%= f.govuk_text_field :query, class: "govuk-input moj-search__input", type: "search", label: { size: 's' } %>
    </div>
    <%= f.submit "Search", class: "govuk-button moj-search__button" %>
  <% end %>
</div>

<div class="govuk-!-margin-top-3">
  <%= govuk_button_to t('.new_record'), edit_payments_steps_office_code_search_path(return_to_cya: params[:return_to_cya]), method: :get, secondary: true %>
</div>

<p></p>
<% if @search_form.executed? %>
  <h2 id="search-results" class="govuk-heading-m"><%= t('shared.search.search_results', count: @search_form.pagy.count) %></h2>
  <% if @search_form.results.any? %>
    <table class="govuk-table" data-module="moj-sortable-table" aria-describedby="page-title">
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <% %i[laa_reference office_code firm_name ufn defendant_last_name].each do |key| %>
            <%= table_header_with_link(key,
                                       'shared.search.table.header',
                                       search_table_params,
                                       @search_form.sort_by, @search_form.sort_direction, 'payments_claim_search_form') %>
                                   <% end %>
                                   <th scope="col" class="govuk-table__header"><%= t('shared.search.table.header.actions') %></th>
        </tr>
      </thead>
      <tbody class="govuk-table__body app-task-list__items">
        <% @search_form.results.each do |search_result| %>
          <%= step_form @form_object do |f| %>
            <tr class="govuk-table__row app-task-list__item">
              <td class="govuk-table__cell">
                <%= search_result.laa_reference %>
                <%= f.hidden_field(:payable_claim_id, value: search_result.payable_claim_id) %>
                <%= f.hidden_field(:claim_type, value: search_result.claim_type) %>
                <%= hidden_field_tag "#{f.object_name}[return_to_cya]", 1 if params[:return_to_cya].present? %>
              </td>
              <td class="govuk-table__cell">
                <%= search_result.office_code %>
              </td>
              <td class="govuk-table__cell">
                <%= search_result.firm_name %>
              </td>
              <td class="govuk-table__cell">
                <%= search_result.ufn %>
              </td>
              <td class="govuk-table__cell">
                <%= search_result.defendant_last_name %>
              </td>
              <td class="govuk-table__cell">
                <%= f.submit t(".select"),  class: "govuk-button moj-search__button"%>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
    <%= render 'shared/pagination', pagy: @search_form.pagy, item: t(".result") %>
  <% else %>
    <div><%= t('.no_results_html').html_safe %></div>
  <% end %>
<% end %>
